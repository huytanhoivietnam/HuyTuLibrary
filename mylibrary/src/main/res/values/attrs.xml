<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="GradientTextView">

        <attr name="gtv_startColor" format="color"/>

        <attr name="gtv_endColor" format="color"/>

        <attr name="gtv_orientation">
            <enum name="left_to_right" value="0"/>
            <enum name="right_to_left" value="1"/>
            <enum name="top_to_bottom" value="2"/>
            <enum name="bottom_to_top" value="3"/>
        </attr>

    </declare-styleable>
</resources>